# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MongoDB connection string (Optional - GramGo provides auto in-memory fallback)
MONGO_URI=mongodb://localhost:27017/gramgo

# JSON Web Token secret key for signing passenger and driver session payloads
JWT_SECRET=gramgo_secure_jwt_secret_key_2026

# Google Maps Platform API Key (Required for interactive maps, routes, and location services)
GOOGLE_MAPS_PLATFORM_KEY=

# Optional Payment Gateway Configuration (If omitted, the app runs in secure Sandbox Simulation mode)
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

